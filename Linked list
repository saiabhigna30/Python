from typing import dataclass_transform
class Node:
  def __init__(self,data):
    self.data=data
    self.next=None
class LinkedList:
  def __init__(self):
    self.head=None
  def  insert(self,data):
    newnode=Node(data)  #creation of node
    if self.head==None:
      self.head=newnode
    else:
      temp=self.head
      while(temp.next != None):
        temp=temp.next
      temp.next=newnode
  def display(self):
    temp=self.head
    while temp:
      print(temp.data,end="->")
      temp=temp.next

l=LinkedList() #obj creation
l.insert(100)
l.insert(200)
